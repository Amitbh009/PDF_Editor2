name: Build PDF Editor Pro

on:
  push:
    branches: [ "main", "master" ]
  pull_request:
    branches: [ "main", "master" ]
  workflow_dispatch:

jobs:
  # Android APK Build Job
  build-android:
    name: Build Android APK
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ./flutter_app   # 👈 All commands run inside flutter_app/

    steps:
      - name: 📥 Checkout repository
        uses: actions/checkout@v4

      - name: 🎯 Setup Java
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '17'

      - name: 🐦 Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.x'
          channel: 'stable'
          cache: true

      - name: 📦 Install dependencies
        run: |
          flutter pub get
          # If pub get fails due to version conflicts, try upgrading
          # flutter pub upgrade

      - name: 🔍 Verify setup
        run: flutter doctor -v

      - name: 📱 Build Android APK (debug)
        run: flutter build apk --debug

      - name: 📱 Build Android APK (release)
        run: flutter build apk --release --split-per-abi

      - name: 📤 Upload Android APK artifacts
        uses: actions/upload-artifact@v4
        with:
          name: android-apks
          path: flutter_app/build/app/outputs/flutter-apk/*.apk   # 👈 Path from repo root
          retention-days: 30

  # Windows EXE Build Job
  build-windows:
    name: Build Windows EXE
    runs-on: windows-latest
    defaults:
      run:
        working-directory: ./flutter_app   # 👈 All commands run inside flutter_app/

    steps:
      - name: 📥 Checkout repository
        uses: actions/checkout@v4

      - name: 🐦 Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.x'
          channel: 'stable'
          cache: true

      - name: 📦 Install dependencies
        run: |
          flutter pub get
          # flutter pub upgrade   # uncomment if needed

      - name: 🔍 Verify setup
        run: flutter doctor -v

      - name: 🪟 Enable Windows desktop support
        run: flutter config --enable-windows-desktop

      - name: 🏗️ Build Windows EXE (debug)
        run: flutter build windows --debug

      - name: 🏗️ Build Windows EXE (release)
        run: flutter build windows --release

      - name: 📦 Create Windows release package (optional)
        shell: pwsh
        run: |
          if (Test-Path "build\windows\x64\runner\Release") {
            Compress-Archive -Path build\windows\x64\runner\Release\* -DestinationPath ..\PDF_Editor_Pro_Windows.zip -Force
          }

      - name: 📤 Upload Windows EXE artifacts
        uses: actions/upload-artifact@v4
        with:
          name: windows-exe
          path: |
            flutter_app/build/windows/x64/runner/Debug/pdf_editor_pro.exe
            flutter_app/build/windows/x64/runner/Release/
            PDF_Editor_Pro_Windows.zip    # if created
          retention-days: 30

  # Optional: Create a GitHub Release with all artifacts
  create-release:
    name: Create GitHub Release
    needs: [build-android, build-windows]
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && (github.ref == 'refs/heads/main' || github.ref == 'refs/heads/master')
    
    steps:
      - name: 📥 Download all artifacts
        uses: actions/download-artifact@v4
        with:
          path: artifacts

      - name: 📦 Prepare release assets
        run: |
          mkdir -p release-assets
          cp -r artifacts/android-apks/* release-assets/ 2>/dev/null || true
          cp -r artifacts/windows-exe/* release-assets/ 2>/dev/null || true

      - name: 🏷️ Create GitHub Release
        uses: softprops/action-gh-release@v1
        with:
          name: Release ${{ github.ref_name }} - ${{ github.sha }}
          tag_name: ${{ github.ref_name }}
          body: |
            ## 📄 PDF Editor Pro - Automated Build
            
            This release was automatically built from commit: ${{ github.sha }}
            
            ### 📱 Android APKs
            - Debug & Release (split by architecture)
            
            ### 🖥️ Windows EXE
            - Debug executable
            - Release folder (or ZIP)
          files: release-assets/*
          draft: false
          prerelease: false
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}