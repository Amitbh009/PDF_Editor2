name: Build APK and Windows EXE

on:
  push:
    branches:
      - main
  pull_request:
    branches:
      - main
  workflow_dispatch:

jobs:
  build_apk:
    name: Build Android APK
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: stable

      - name: Show Flutter and Java versions
        run: |
          flutter --version
          java -version

      - name: Get and upgrade Dart/Flutter packages
        run: |
          flutter pub upgrade
          flutter pub get

      - name: Regenerate platform files (non-destructive)
        run: |
          # regenerate platform files to match the SDK (will not overwrite lib/)
          flutter create .

      - name: Accept Android licenses
        run: yes | flutter doctor --android-licenses

      - name: Build release APK
        run: flutter build apk --release

      - name: Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: android-apk
          path: |
            build/app/outputs/flutter-apk/app-release.apk
            build/app/outputs/flutter-apk/app.apk

  build_windows:
    name: Build Windows EXE (generate platform files if missing)
    runs-on: windows-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: stable

      - name: Enable Windows desktop
        run: flutter config --enable-windows-desktop

      - name: Show Flutter
        run: flutter --version

      - name: Get and upgrade Dart/Flutter packages
        run: |
          flutter pub upgrade
          flutter pub get

      - name: Regenerate Windows platform files if missing
        shell: pwsh
        run: |
          # If windows/runner/CMakeLists.txt or windows/runner doesn't exist, regenerate windows platform
          if (-not (Test-Path -Path windows\runner\CMakeLists.txt)) {
            Write-Host "windows/runner/CMakeLists.txt missing — running flutter create --platforms=windows ."
            flutter create --platforms=windows .
          } else {
            Write-Host "Windows platform files present"
          }

      - name: Build release Windows executable
        run: flutter build windows --release

      - name: Pack Windows build directory (zip)
        shell: pwsh
        run: |
          $out = "windows-build.zip"
          if (Test-Path -Path build\windows\runner\Release) {
            Compress-Archive -Path build\windows\runner\Release\* -DestinationPath $out -Force
            Write-Host "Created $out"
          } else {
            Write-Host "Windows build output not found: build\\windows\\runner\\Release"
            exit 1
          }

      - name: Upload Windows artifact
        uses: actions/upload-artifact@v4
        with:
          name: windows-exe
          path: windows-build.zip