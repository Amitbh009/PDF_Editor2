name: Build PDFForge

on:
  push:
    branches: [main]
  workflow_dispatch: # allow manual trigger from GitHub UI

# ─────────────────────────────────────────────────────────────────────────────
# HOW THIS WORKS:
# The flutter_app folder contains lib/ and pubspec.yaml (source code only).
# Platform folders (android/, windows/, web/) do NOT exist in the repo.
# Each job:
#   1. Creates a blank Flutter project in a temp folder
#   2. Copies our lib/ and pubspec.yaml into it
#   3. Runs flutter pub get
#   4. Builds the target platform
# This is the correct approach when you don't commit platform folders.
# ─────────────────────────────────────────────────────────────────────────────

jobs:

  # ─── Android APK ────────────────────────────────────────────────────────────
  build-android:
    name: Build Android APK
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Java 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'

      - name: Set up Flutter 3.22.2
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.22.2'
          channel: stable
          cache: true

      - name: Disable analytics
        run: flutter config --no-analytics

      - name: Create fresh Flutter project scaffold
        run: |
          flutter create --org com.pdfforge --project-name pdfforge /tmp/pdfforge_build
          echo "Scaffold created at /tmp/pdfforge_build"
          ls -la /tmp/pdfforge_build

      - name: Copy our source code into the scaffold
        run: |
          # Replace the generated lib/ and pubspec.yaml with ours
          rm -rf /tmp/pdfforge_build/lib
          cp -r flutter_app/lib /tmp/pdfforge_build/lib
          cp flutter_app/pubspec.yaml /tmp/pdfforge_build/pubspec.yaml
          echo "Source code copied successfully"
          ls -la /tmp/pdfforge_build/lib

      - name: Install dependencies
        run: flutter pub get
        working-directory: /tmp/pdfforge_build

      - name: Flutter doctor (debug)
        run: flutter doctor -v
        working-directory: /tmp/pdfforge_build

      - name: Build APK release
        run: flutter build apk --release --no-tree-shake-icons
        working-directory: /tmp/pdfforge_build

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: PDFForge-Android-APK
          path: /tmp/pdfforge_build/build/app/outputs/flutter-apk/app-release.apk
          retention-days: 30

  # ─── Android App Bundle ──────────────────────────────────────────────────────
  build-aab:
    name: Build Android App Bundle (Play Store)
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Java 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'

      - name: Set up Flutter 3.22.2
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.22.2'
          channel: stable
          cache: true

      - name: Disable analytics
        run: flutter config --no-analytics

      - name: Create fresh Flutter scaffold
        run: flutter create --org com.pdfforge --project-name pdfforge /tmp/pdfforge_build

      - name: Copy our source code
        run: |
          rm -rf /tmp/pdfforge_build/lib
          cp -r flutter_app/lib /tmp/pdfforge_build/lib
          cp flutter_app/pubspec.yaml /tmp/pdfforge_build/pubspec.yaml

      - name: Install dependencies
        run: flutter pub get
        working-directory: /tmp/pdfforge_build

      - name: Build App Bundle
        run: flutter build appbundle --release --no-tree-shake-icons
        working-directory: /tmp/pdfforge_build

      - name: Upload AAB
        uses: actions/upload-artifact@v4
        with:
          name: PDFForge-Android-AAB
          path: /tmp/pdfforge_build/build/app/outputs/bundle/release/app-release.aab
          retention-days: 30

  # ─── Windows Desktop ─────────────────────────────────────────────────────────
  build-windows:
    name: Build Windows Desktop EXE
    runs-on: windows-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Flutter 3.22.2
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.22.2'
          channel: stable
          cache: true

      - name: Disable analytics & enable Windows
        run: |
          flutter config --no-analytics
          flutter config --enable-windows-desktop

      - name: Create fresh Flutter scaffold (Windows)
        run: flutter create --org com.pdfforge --project-name pdfforge C:\pdfforge_build

      - name: Copy our source code
        shell: pwsh
        run: |
          Remove-Item -Recurse -Force C:\pdfforge_build\lib -ErrorAction SilentlyContinue
          Copy-Item -Recurse flutter_app\lib C:\pdfforge_build\lib
          Copy-Item flutter_app\pubspec.yaml C:\pdfforge_build\pubspec.yaml
          Write-Host "Files copied:"
          Get-ChildItem C:\pdfforge_build\lib

      - name: Install dependencies
        run: flutter pub get
        working-directory: C:\pdfforge_build

      - name: Build Windows release
        run: flutter build windows --release --no-tree-shake-icons
        working-directory: C:\pdfforge_build

      - name: Upload Windows EXE
        uses: actions/upload-artifact@v4
        with:
          name: PDFForge-Windows-EXE
          path: C:\pdfforge_build\build\windows\x64\runner\Release\
          retention-days: 30

  # ─── Web Build ───────────────────────────────────────────────────────────────
  build-web:
    name: Build Web App
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Flutter 3.22.2
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.22.2'
          channel: stable
          cache: true

      - name: Disable analytics
        run: flutter config --no-analytics

      - name: Create fresh Flutter scaffold
        run: flutter create --org com.pdfforge --project-name pdfforge /tmp/pdfforge_build

      - name: Copy our source code
        run: |
          rm -rf /tmp/pdfforge_build/lib
          cp -r flutter_app/lib /tmp/pdfforge_build/lib
          cp flutter_app/pubspec.yaml /tmp/pdfforge_build/pubspec.yaml

      - name: Install dependencies
        run: flutter pub get
        working-directory: /tmp/pdfforge_build

      - name: Build Web release
        run: flutter build web --release --no-tree-shake-icons
        working-directory: /tmp/pdfforge_build

      - name: Upload Web build
        uses: actions/upload-artifact@v4
        with:
          name: PDFForge-Web
          path: /tmp/pdfforge_build/build/web/
          retention-days: 30